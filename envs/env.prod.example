# ═══════════════════════════════════════════════════════════════
#  PROD environment — Clinical AI Multi-Agent
# ═══════════════════════════════════════════════════════════════
#  Copia a envs/.env.prod y reemplazá TODOS los placeholders CHANGE_ME.
#  NUNCA commitees envs/.env.prod — ya está en .gitignore.
#
#  Checklist antes de deployar:
#    [ ] POSTGRES_PASSWORD cambiado (32+ chars, aleatorios)
#    [ ] GROQ_API_KEY o OPENAI_API_KEY con key real
#    [ ] DATABASE_URL consistente con POSTGRES_*
#    [ ] DEBUG=false (verificado)
# ═══════════════════════════════════════════════════════════════

# ─── Database ──────────────────────────────────────────────────
POSTGRES_USER=clinical_ai_prod
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_32_CHARS_MIN
POSTGRES_DB=clinical_ai

DATABASE_URL=postgresql+asyncpg://clinical_ai_prod:CHANGE_ME_STRONG_PASSWORD_32_CHARS_MIN@postgres:5432/clinical_ai

# ─── LLM Provider ──────────────────────────────────────────────
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile
GROQ_API_KEY=CHANGE_ME_GROQ_KEY
GROQ_BASE_URL=https://api.groq.com/openai/v1

# ─── OpenAI (embeddings RAG) ───────────────────────────────────
OPENAI_API_KEY=CHANGE_ME_OPENAI_KEY
EMBEDDING_MODEL=text-embedding-3-small

# ─── LM Studio ────────────────────────────────────────────────
LMSTUDIO_BASE_URL=

# ─── App ───────────────────────────────────────────────────────
# IMPORTANTE: DEBUG=false en prod — no expongas stack traces
DEBUG=false

# Environment / startup policy
APP_ENV=production

# En producción NO queremos create_all(). El schema se gestiona con Alembic.
STARTUP_DB_INIT_MODE=skip

# /ready debe verificar que la DB responde.
READINESS_CHECK_DB=true

# /health en prod no debería exponer detalles internos innecesarios.
HEALTH_EXPOSE_DETAILS=false

# Si falla la inicialización de startup, el proceso debe fallar rápido.
FAIL_STARTUP_ON_INIT_ERROR=true
