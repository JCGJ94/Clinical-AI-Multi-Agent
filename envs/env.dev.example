# ═══════════════════════════════════════════════════════════════
#  DEV environment — Clinical AI Multi-Agent
# ═══════════════════════════════════════════════════════════════
#  Copia este archivo a envs/.env.dev y completá los secrets.
#  NUNCA commitees envs/.env.dev — ya está en .gitignore.
#
#  Uso:
#    cp envs/env.dev.example envs/.env.dev
#    # editá GROQ_API_KEY y OPENAI_API_KEY
#    ./scripts/dev-up.sh
# ═══════════════════════════════════════════════════════════════

# ─── Database (pgvector) ───────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=clinical_ai

# Hostname "postgres" = nombre del servicio en compose (DNS interno Docker)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/clinical_ai

# ─── LLM Provider ──────────────────────────────────────────────
# Opciones: groq | openai | lmstudio
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile

# Groq — free tier, ideal para dev
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1

# ─── OpenAI (solo para embeddings RAG) ─────────────────────────
# El API NO la necesita si no usás RAG.
# El indexer SÍ la necesita obligatoriamente.
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small

# ─── LM Studio (opcional — solo si LLM_PROVIDER=lmstudio) ─────
LMSTUDIO_BASE_URL=http://host.docker.internal:1234/v1

# ─── App ───────────────────────────────────────────────────────
DEBUG=true

# Environment / startup policy
APP_ENV=development

# En desarrollo sí queremos create_all() para bootstrap rápido.
STARTUP_DB_INIT_MODE=create_all

# /ready también puede chequear DB en dev para detectar roturas antes.
READINESS_CHECK_DB=true

# En dev está bien exponer más detalles en /health.
HEALTH_EXPOSE_DETAILS=true

# Si el startup falla en dev, preferimos enterarnos de inmediato.
FAIL_STARTUP_ON_INIT_ERROR=true
