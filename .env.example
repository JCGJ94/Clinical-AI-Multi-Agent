# This is an example .env file for the Clinical AI project.
# Copy this file to .env and fill in the appropriate values.
# LLM_PROVIDER: The provider of the language model (e.g., "groq", "openai", "azure").
# LLM_MODEL: The specific model to use from the provider (e.g., "llama-3.3-70b-versatile" for Groq).
# GROQ_API_KEY: Your API key for the Groq provider. Replace "gsk_TU_KEY_AQUI" with your actual API key.
# DATABASE_URL: The connection string for your PostgreSQL database. Adjust the username, password, host, port, and database name as needed.
# DEBUG: Set to "true" to enable debug mode, or "false" to disable it.

LLM_PROVIDER=groq                                                                                                                                              
LLM_MODEL=llama-3.3-70b-versatile                                       
GROQ_API_KEY=gsk_TU_KEY_AQUI
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/clinical_ai                                                                                 
DEBUG=false 